{
  "connector.class": "io.confluent.connect.elasticsearch.ElasticsearchSinkConnector",
  "connection.url": "http://elasticsearch:9200",
  "type.name": "_doc",
  "topics": "university.public.university,university.public.institute,university.public.department,university.public.speciality,university.public.department_specialities,university.public.lecture_course,university.public.lecture,university.public.lecture_material,university.public.student_group,university.public.student,university.public.schedule,university.public.attendance",
  "key.ignore": "false",
  "behavior.on.null.values": "delete",
  "behavior.on.malformed.documents": "warn",
  "schema.ignore": "true",
  "batch.size": "2000",
  "linger.ms": "1000",
  "max.retries": "5",
  "retry.backoff.ms": "1000",
  "max.buffered.records": "20000",
  "flush.synchronously": "true",
  "tasks.max": "1",
  "transforms": "unwrap,route,extractId",
  "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
  "transforms.unwrap.drop.tombstones": "false",
  "transforms.unwrap.delete.handling.mode": "none",
  "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
  "transforms.route.regex": "university\\.public\\.(.*)",
  "transforms.route.replacement": "pg_$1",
  "transforms.extractId.type": "org.apache.kafka.connect.transforms.ExtractField$Key",
  "transforms.extractId.field": "id",
  "key.converter": "org.apache.kafka.connect.json.JsonConverter",
  "value.converter": "org.apache.kafka.connect.json.JsonConverter",
  "key.converter.schemas.enable": "true",
  "value.converter.schemas.enable": "true"
}
