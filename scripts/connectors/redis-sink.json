{
  "connector.class": "io.lenses.streamreactor.connect.redis.sink.RedisSinkConnector",
  "tasks.max": "1",
  "topics": "university.public.student,university.public.student_group",
  "connect.redis.host": "redis",
  "connect.redis.port": "6379",
  "connect.redis.kcql": "INSERT INTO _ignore SELECT * FROM university.public.student PK id;INSERT INTO _ignore SELECT * FROM university.public.student_group PK id",
  "transforms": "unwrap,redisHash",
  "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
  "transforms.unwrap.drop.tombstones": "false",
  "transforms.unwrap.delete.handling.mode": "none",
  "transforms.redisHash.type": "com.example.RedisHashCdcHandler",
  "transforms.redisHash.pk.field": "id",
  "transforms.redisHash.redis.host": "redis",
  "transforms.redisHash.redis.port": "6379",
  "key.converter": "org.apache.kafka.connect.json.JsonConverter",
  "value.converter": "org.apache.kafka.connect.json.JsonConverter",
  "key.converter.schemas.enable": "true",
  "value.converter.schemas.enable": "true"
}
